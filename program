from qadratic_func import * # Импорт функции

# Основной цикл программы для ввода и проверки корректности значений
print("""\n!!!Программа для решения квадратных уравнений!!!""")
while True: # Проверка на ввод числовых значений
    try:
        val_a = float(input("\nВведите коэффициент a: ")) # Значение старшего коэффициента
        val_b = float(input("Введите коэффициент b: "))   # Значение второго коэффициента
        val_c = float(input("Введите коэффициент c: "))   # Значение свободного члена

        ###  Для доп.проверки на запятую используйте пример:input(а).replace(',', '.') и вернуть к float a = float(a) и использовать метод проверки <isdigit>

        # Вызов функции решения квадратного уравнения и вывод результата
        result = solve_quadratic(val_a, val_b, val_c) # Вызов функции решения квадратного уравнения
        print(result) # Вывод результата
        break

    except ValueError: # Проверка на числовые значения не пройдена.
        print(
            """Ошибка!!! Введены некорректные данные. Возможно присутствуют буквы или запятые.
          Попробуйте еще раз.""")
        continue # Для повторного ввода данных или поставить <break> для завершения цикла.
