from math import sqrt

def solve_quadratic(a, b, c):
    """Функция для решения квадратного уравнения (ax^2 + bx + c = 0)"""
    if a == 0:
        return "Внимание!!! Значение (a) не может быть равным нулю. Это не квадратное уравнение. Попробуйте еще раз."

    d = b ** 2 - 4 * a * c # Считаем дискриминант

    if d < 0: # Если дискриминант меньше нуля, уравнение не имеет корней
        return "Уравнение не имеет корней"

    elif d > 0: # Если дискриминант больше нуля, уравнение имеет два корня
        x1 = (-b + sqrt(d)) / (2 * a) # Считаем первый корень
        x2 = (-b - sqrt(d)) / (2 * a) # Считаем второй корень
        return f"Уравнение имеет два корня: {x1:.5f} и {x2:.5f}" # Вывод корней с точностью 5 знаков после запятой

    else: # При значении (d == 0) уравнение имеет один корень
        x = -b / (2 * a) # Считаем первый корень
        return f"Уравнение имеет один корень: {x:.5f}" # Вывод корня с точностью 5 знаков после запятой
